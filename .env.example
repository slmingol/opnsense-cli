# OPNsense API credentials
# Generate at: System > Access > Users > (user) > API keys
OPNSENSE_HOST=https://opnsense-rtr1.bub.lan
OPNSENSE_API_KEY=your-api-key-here
OPNSENSE_API_SECRET=your-api-secret-here

# Optional: disable SSL verification for self-signed certs
# NODE_TLS_REJECT_UNAUTHORIZED=0

# WireGuard private key — overrides PrivateKey in .conf so the file can be committed safely.
# WG_PRIVATE_KEY=your-base64-private-key-here

# NordVPN access token — used by nordvpn:creds and nordvpn:rotate-wg.
# Obtain from https://my.nordaccount.com/dashboard/nordvpn/access-tokens/
# NORDVPN_TOKEN=your-nordvpn-access-token-here

# Minimum required OPNsense version: 25.7 (snake_case API endpoints)
# Kea DHCP must be enabled (System > Settings > Administration > DHCP backend)
